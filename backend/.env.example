# =====================================================================
# EmploYA backend — environment variables
# Copy this file to `.env.local` and fill in real values.
#   cp .env.example .env.local
# `.env.local` is gitignored.
# =====================================================================

# ---- Supabase ------------------------------------------------------
# Project settings → API. Used by both server and (where safe) client code.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Anon (public) key — safe to expose to the browser. Bound by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the
# browser; never prefix with NEXT_PUBLIC_. Use it inside route handlers
# (src/app/api/**) when you need admin-level writes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Direct Postgres connection string (Project settings → Database).
# Use this if you wire Drizzle / Prisma / Kysely directly to Postgres
# instead of going through the Supabase JS client.
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Supabase JWT secret — only needed if you verify Supabase auth JWTs in
# `src/lib/auth.ts` instead of calling `supabase.auth.getUser()`.
SUPABASE_JWT_SECRET=your-jwt-secret-from-project-settings

# ---- LLM provider (later, when you replace the fake engines) -------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ---- Dev knobs -----------------------------------------------------
# Set to 1 to allow unauthenticated requests (the fake auth in
# src/lib/auth.ts will return userId="anon"). DO NOT enable in prod.
ALLOW_ANON=0

# Override the dev server port (default 3001 from package.json scripts).
# PORT=3001
